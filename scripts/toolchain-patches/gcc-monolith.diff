--- /dev/null
+++ b/gcc/config/monolith.h
@@ -0,0 +1,22 @@
+/* MONOLITH target configuration.  See OSDev OS Specific Toolchain. */
+#undef TARGET_MONOLITH
+#define TARGET_MONOLITH 1
+
+#undef LIB_SPEC
+#define LIB_SPEC "-lc"
+
+#undef STARTFILE_SPEC
+#define STARTFILE_SPEC "crt0.o%s crti.o%s crtbegin.o%s"
+
+#undef ENDFILE_SPEC
+#define ENDFILE_SPEC "crtend.o%s crtn.o%s"
+
+#undef TARGET_OS_CPP_BUILTINS
+#define TARGET_OS_CPP_BUILTINS()        \
+  do {                                  \
+    builtin_define ("__monolith__");    \
+    builtin_define ("__unix__");        \
+    builtin_assert ("system=monolith"); \
+    builtin_assert ("system=unix");     \
+    builtin_assert ("system=posix");    \
+  } while (0)
